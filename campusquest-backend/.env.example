# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Reemplaza con tu cadena de conexión real de MongoDB Atlas
# La encuentras en: Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@campusquest-cluster.grcjhb.mongodb.net/campusquest?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Llave secreta para firmar los tokens JWT (pon cualquier string largo y aleatorio)
JWT_SECRET=campusquest_secret_key_muy_larga_y_segura_2024

# Tiempo de expiración del token (ej: 7d = 7 días, 1h = 1 hora)
JWT_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
